SECRET_KEY=your-secret-key

# 服务端口：开发 6002，打包/生产 6001（由启动脚本或 FLASK_DEBUG 决定）
# PORT=6002
# FLASK_DEBUG=0

# 可选：ChromeDriver 路径（不设置则按本机 Chrome 版本从国内镜像自动下载并缓存）
# CHROMEDRIVER_PATH=D:/driver/chromedriver.exe
# CHROMEDRIVER_CACHE_DIR=driver_cache/chromedriver

# 推荐：使用独立配置项，密码可包含 @ # % 等特殊字符，无需手动转义
DB_HOST=www.whatwin.net
DB_PORT=10003
DB_USER=root
DB_PASSWORD=WHATwin1688@%^=,.
DB_NAME=test-merge-play

# 备选：完整连接串（密码含特殊字符时需手动 URL 编码，如 @ 写成 %40）
# DATABASE_URL=mysql+pymysql://root:pass%40word@localhost:3306/task_manager?charset=utf8mb4
